  },
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@vercel/ncc": "^0.38.4",
    "@yao-pkg/pkg": "^6.15.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.3"
  }
}
